  "content": "<!-- Capabilities section -->\r\n      <div id=\"caps-section\" class=\"caps-section\" style=\"display:none\">\r\n        <h3>Advanced Capabilities</h3>\r\n        <div id=\"caps-notice\" class=\"caps-notice\" style=\"display:none\"></div>\r\n        <div id=\"caps-toggles\" style=\"display:none\">\r\n          <div class=\"cap-toggle\">\r\n            <label><input type=\"checkbox\" id=\"cap-cache\" checked> Extended cache (1-hour)</label>\r\n            <span class=\"cap-desc\">Longer prompt caching TTL</span>\r\n          </div>\r\n          <div class=\"cap-toggle\">\r\n            <label><input type=\"checkbox\" id=\"cap-compaction\"> Compaction</label>\r\n            <span class=\"cap-desc\">Smarter context compression</span>\r\n          </div>\r\n          <div class=\"cap-toggle\">\r\n            <label><input type=\"checkbox\" id=\"cap-thinking\"> Extended thinking</label>\r\n            <span class=\"cap-desc\">Deeper reasoning on complex tasks</span>\r\n          </div>\r\n          <div id=\"thinking-budget-row\" class=\"cap-budget\" style=\"display:none\">\r\n            <label>Budget</label>\r\n            <input type=\"range\" id=\"cap-thinking-budget\" min=\"1024\" max=\"16384\" step=\"1024\" value=\"4096\" oninput=\"document.getElementById('cap-thinking-val').textContent=this.value\">\r\n            <span class=\"cap-val\" id=\"cap-thinking-val\">4096</span>\r\n          </div>\r\n          <div class=\"cap-toggle\">\r\n            <label><input type=\"checkbox\" id=\"cap-native-tools\" checked> Native tool use</label>\r\n            <span class=\"cap-desc\">Structured function calling</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"btn-row\">\r\n        <button class=\"btn-cancel\" onclick=\"toggleConfig()\">Cancel</button>\r\n        <button class=\"btn-save\" onclick=\"saveConfig()\">Save</button>\r\n      </div>\r\n    </div>",
