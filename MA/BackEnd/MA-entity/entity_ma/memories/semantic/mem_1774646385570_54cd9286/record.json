  "content": "<!-- Ingest panel -->\r\n<div id=\"ingest-panel\">\r\n  <div class=\"config-box\" style=\"width:500px\">\r\n    <h2 style=\"margin:0 0 12px;font-size:18px;color:var(--text)\">Memory Ingest</h2>\r\n    <div class=\"ingest-section\">\r\n      <p style=\"font-size:13px;color:var(--dim);margin:0 0 10px\">Ingest a folder. All text files will be chunked and stored as a named archive.</p>\r\n      <label>Folder Path</label>\r\n      <input id=\"ingest-folder-path\" placeholder=\"C:\\\\Projects\\\\my-app\">\r\n      <label>Archive Name <span style=\"color:var(--dim);font-size:11px\">(blank = folder name)</span></label>\r\n      <input id=\"ingest-archive-name\" placeholder=\"my-app\">\r\n      <button class=\"btn-save\" id=\"ingest-folder-btn\" onclick=\"ingestFolder()\" style=\"margin-top:8px\">Ingest Folder</button>\r\n    </div>\r\n    <hr style=\"border:none;border-top:1px solid var(--border);margin:14px 0\">\r\n    <div class=\"ingest-section\">\r\n      <h3 style=\"font-size:14px;margin:0 0 8px;color:var(--text)\">Archives</h3>\r\n      <div id=\"ingest-archives-list\" style=\"font-size:12px;color:var(--dim)\">Loading...</div>\r\n    </div>\r\n    <div class=\"btn-row\" style=\"margin-top:12px\">\r\n      <button class=\"btn-cancel\" onclick=\"toggleIngestPanel()\">Close</button>\r\n    </div>\r\n  </div>\r\n</div>\r\n\n<!-- Ingest progress overlay -->\r\n<div id=\"ingest-progress-overlay\">",
