  "content": "<!-- LLM pane -->\r\n    <div id=\"cfg-llm\" class=\"cfg-pane active\">\r\n      <label>Provider</label>\r\n      <select id=\"cfg-type\">\r\n        <option value=\"openrouter\">OpenRouter</option>\r\n        <option value=\"ollama\">Ollama</option>\r\n        <option value=\"anthropic\">Anthropic Direct</option>\r\n      </select>\r\n      <label>Endpoint URL</label>\r\n      <input id=\"cfg-endpoint\" placeholder=\"https://openrouter.ai/api/v1/chat/completions\">\r\n      <label>API Key (blank for Ollama)</label>\r\n      <div class=\"key-row\">\r\n        <input id=\"cfg-key\" type=\"password\" placeholder=\"sk-or-...\">\r\n        <button class=\"key-toggle\" id=\"cfg-key-toggle\" type=\"button\" onclick=\"toggleCfgKeyVisibility()\">See</button>\r\n      </div>\r\n      <label>Model</label>\r\n      <div id=\"model-text-wrap\">\r\n        <input id=\"cfg-model\" list=\"cfg-model-datalist\" placeholder=\"anthropic/claude-sonnet-4\">\r\n        <datalist id=\"cfg-model-datalist\"></datalist>\r\n      </div>\r\n      <div id=\"model-ollama-wrap\" style=\"display:none\">\r\n        <div class=\"model-row\">\r\n          <select id=\"cfg-model-select\" onchange=\"onOllamaModelSelect()\"><option value=\"\">-- select a model --</option></select>\r\n          <button onclick=\"loadOllamaModels()\" title=\"Refresh model list\">&#x27F3;</button>\r\n        </div>\r\n        <div id=\"model-info\"></div>\r\n        <div class=\"pull-row\">\r\n          <input id=\"cfg-pull-name\" placeholder=\"Pull a model (e.g. llama3.1:8b)\">\r\n          <button onclick=\"pullOllamaModel()\">Pull</button>\r\n        </div>\r\n        <div id=\"pull-status\"></div>\r\n      </div>\r\n      <label>Max Tokens <span id=\"cfg-tokens-val\" style=\"color:var(--accent)\">12288</span></label>\r\n      <input id=\"cfg-tokens\" type=\"range\" min=\"1024\" max=\"1000000\" step=\"1024\" value=\"12288\" oninput=\"document.getElementById('cfg-tokens-val').textContent=this.value\" style=\"accent-color:var(--accent)\">\r\n      <div id=\"cfg-tokens-hint\" style=\"font-size:12px;color:var(--dim);margin-top:4px\">20% of Max Tokens is reserved for MA's reply.</div>\r\n      <label style=\"display:flex;align-items:center;gap:8px;cursor:pointer\"><input id=\"cfg-vision\" type=\"checkbox\" style=\"accent-color:var(--accent)\"> Vision (model supports images)</label>\r\n      <label>Workspace Path <span style=\"color:var(--dim);font-size:11px\">(blank = default MA-workspace/)</span></label>\r\n      <input id=\"cfg-workspace\" placeholder=\"MA-workspace\">\r\n      <label>Integration Mode</label>\r\n      <select id=\"cfg-integration-mode\">\r\n        <option value=\"off\">Off (Standalone)</option>\r\n        <option value=\"nekocore\">NekoCore Integration</option>\r\n      </select>\r\n      <label>Theme</label>\r\n      <select id=\"cfg-theme\">\r\n        <option value=\"system\">Use Browser Preference</option>\r\n        <option value=\"dark\">Dark</option>\r\n        <option value=\"light\">Light</option>\r\n      </select>\r\n      <label>Memory Recall <span id=\"cfg-mem-limit-val\" style=\"color:var(--accent)\">6</span></label>\r\n      <input id=\"cfg-mem-limit\" type=\"range\" min=\"6\" max=\"50\" step=\"1\" value=\"6\" oninput=\"document.getElementById('cfg-mem-limit-val').textContent=this.value\" style=\"accent-color:var(--accent)\">\r\n      <label style=\"display:flex;align-items:center;gap:8px;cursor:pointer\"><input id=\"cfg-mem-recall\" type=\"checkbox\" checked style=\"accent-color:var(--accent)\"> Enable memory recall in chat</label>\r\n      <label style=\"display:flex;align-items:center;gap:8px;cursor:pointer;margin-top:6px\"><input id=\"cfg-autopilot\" type=\"checkbox\" style=\"accent-color:var(--accent)\"> Auto Pilot <span style=\"font-size:11px;color:var(--dim)\">(no timeout popups — let MA run freely)</span></label>\r\n      <div class=\"btn-row\" style=\"margin-top:10px\">\r\n        <button class=\"btn-cancel\" type=\"button\" onclick=\"resetWorkspaceLayout()\">Reset Workspace Layout</button>\r\n      </div>",
